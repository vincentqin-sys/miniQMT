# miniQMT 环境变量配置示例
# 复制此文件为 .env，填入实际值后在启动前加载
#
# Windows PowerShell 加载方式：
#   Get-Content .env | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim(), 'Process') } }
#   python main.py
#
# Windows CMD 加载方式：
#   for /f "tokens=1,2 delims==" %i in (.env) do set %i=%j
#   python main.py

# ======================= QMT 路径配置 =======================
# QMT 客户端安装路径（userdata_mini 目录），优先级高于 account_config.json
# 示例：C:/光大证券金阳光QMT实盘/userdata_mini
# QMT_PATH=C:/your-broker-qmt/userdata_mini

# ======================= Web API 访问控制 =======================
# Web API Token，用于保护敏感接口（买入/卖出/配置修改等）
# 留空或不设置：跳过 Token 验证（仅限纯内网部署）
# 设置后：所有 POST 请求需在请求头携带 X-API-Token: <token>
# 建议使用随机字符串，例如：openssl rand -hex 32
QMT_API_TOKEN=Let_Me_Be_Your_Token_1234567890
